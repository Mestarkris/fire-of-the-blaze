# Copy this file to .env and fill in the values from https://dev.blaze.stream/applications
BLAZE_CLIENT_ID=your_client_id_here
BLAZE_CLIENT_SECRET=your_client_secret_here

# Must exactly match a redirect URL you registered on dev.blaze.stream
BLAZE_REDIRECT_URI=http://localhost:3000/auth/callback

# Any random long string - used to sign the local session cookie
SESSION_SECRET=change_this_to_something_random

# Port the local server runs on
PORT=3000
